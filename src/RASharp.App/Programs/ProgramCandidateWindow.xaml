<Window x:Class="RASharp.App.Programs.ProgramCandidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择同名程序"
        Icon="/Assets/RASharp.ico"
        Width="880" Height="520" MinWidth="640" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="2,0,2,12">
            <TextBlock Text="发现多个同名程序" FontSize="21" FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap">
                <Run Text="请为 " />
                <Run x:Name="ExecutableRun" FontWeight="SemiBold" />
                <Run Text=" 选择要运行的程序。选择结果会保存到无路径缓存。" />
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundBrush}">
            <ListView x:Name="CandidatesListView"
                      BorderThickness="0"
                      ItemsSource="{Binding}"
                      MouseDoubleClick="CandidatesListView_MouseDoubleClick">
                <ListView.View>
                    <GridView AllowsColumnReorder="True">
                        <GridViewColumn Header="程序路径" Width="540" DisplayMemberBinding="{Binding Path}" />
                        <GridViewColumn Header="版本" Width="110" DisplayMemberBinding="{Binding Version}" />
                        <GridViewColumn Header="修改时间" Width="170" DisplayMemberBinding="{Binding LastWriteTime}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="CountTextBlock" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" IsCancel="True" MinWidth="86" Padding="16,7" Margin="0,0,10,0" />
                <Button Content="确定" IsDefault="True" MinWidth="86" Padding="16,7"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}" Click="Confirm_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

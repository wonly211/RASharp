<Window x:Class="RASharp.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RASharp 设置"
        Icon="/Assets/RASharp.ico"
        Width="720" Height="640" MinWidth="640" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="MinWidth" Value="86" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="4,0,4,16">
            <TextBlock Text="RASharp 设置" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="保存后立即更新正在运行的菜单和输入服务。" Margin="0,5,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
        </StackPanel>

        <TabControl Grid.Row="1" FontSize="14">
            <TabItem Header="常规">
                <StackPanel Margin="24">
                    <TextBlock Text="启动" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="登录 Windows 后自动启动 RASharp" />
                    <TextBlock Text="启动项只写入当前用户注册表，不需要管理员权限。RASharp 会携带当前配置目录启动。"
                               TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="24,0,0,18" />
                    <Separator />
                    <TextBlock Text="配置目录" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,8" />
                    <TextBox x:Name="ConfigDirectoryTextBox" IsReadOnly="True" />
                    <TextBlock Text="默认配置目录为 RASharp.exe 所在目录下的 Config；也可由 --config-dir 或环境变量覆盖。"
                               TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0" />
                    <Separator Margin="0,18,0,0" />
                    <TextBlock Text="外观主题" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,8" />
                    <ComboBox x:Name="ThemeModeComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="跟随 Windows 系统主题" />
                        <ComboBoxItem Content="始终使用浅色主题" />
                        <ComboBoxItem Content="始终使用深色主题" />
                    </ComboBox>
                    <TextBlock Text="保存后立即应用；跟随系统时会自动响应 Windows 浅色和深色模式切换。"
                               TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </TabItem>

            <TabItem Header="热键">
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="主菜单热键" VerticalAlignment="Center" />
                    <TextBox x:Name="MenuHotKeyTextBox" Grid.Column="1" />
                    <TextBlock Grid.Row="1" Text="菜单2热键" VerticalAlignment="Center" Margin="0,18,0,0" />
                    <TextBox x:Name="Menu2HotKeyTextBox" Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" />
                    <TextBlock Grid.Row="2" Text="打开设置热键" VerticalAlignment="Center" Margin="0,18,0,0" />
                    <TextBox x:Name="SettingsHotKeyTextBox" Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" />
                    <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource InfoBackgroundBrush}" CornerRadius="5" Padding="14" Margin="0,24,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   Text="使用 RunAny/AHK 写法：^ Ctrl、! Alt、+ Shift、# Win。例如 #s 表示 Win+S，^!Space 表示 Ctrl+Alt+Space。Win 组合被系统保留时会自动使用抢占式键盘钩子，吞掉原 Windows 快捷键。菜单2留空表示不注册。" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="无路径缓存">
                <StackPanel Margin="24">
                    <CheckBox x:Name="EnableCacheCheckBox" Content="启用无路径程序解析缓存" />
                    <TextBlock Text="缓存命中前仍会确认目标文件存在；失效路径不会继续使用。关闭后，每次载入均重新通过 Everything 搜索。"
                               TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="24,0,0,18" />
                    <TextBlock Text="缓存文件" FontWeight="SemiBold" Margin="0,8,0,6" />
                    <TextBox x:Name="CachePathTextBox" IsReadOnly="True" />
                    <TextBlock x:Name="CacheInfoTextBlock" Margin="0,8,0,18" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="清空并重建缓存" Click="ClearCache_Click" />
                        <TextBlock x:Name="ClearCacheStatusTextBlock" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{DynamicResource SuccessTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="图标">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <TextBlock Text="图标缓存目录" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="IconCacheDirectoryTextBox" IsReadOnly="True" />
                        <TextBlock Text="菜单优先读取 PNG 缓存，未命中时才调用 Windows SHGetFileInfo。"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,7,0,18" />

                        <TextBlock Text="人工指定程序或文件图标" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="IconItemComboBox"
                                  DisplayMemberPath="Description"
                                  FontSize="14" Padding="6" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IconSourceTextBox" />
                            <Button Grid.Column="1" Content="浏览…" Margin="10,0,0,0" Click="BrowseIcon_Click" />
                        </Grid>
                        <TextBlock Text="支持 PNG、ICO、JPG、BMP，也可以从 EXE、DLL、文件或文件夹中提取系统图标。"
                                   TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,7,0,14" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="指定所选图标" Click="ApplyIconOverride_Click" />
                            <Button Content="清空并全部重新提取" Margin="10,0,0,0" Click="ClearIconCache_Click" />
                        </StackPanel>
                        <TextBlock x:Name="IconCacheStatusTextBlock"
                                   Margin="0,10,0,0" Foreground="{DynamicResource SuccessTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Everything">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <CheckBox x:Name="EnableEverythingCheckBox" Content="由 RASharp 集成并管理 Everything" />
                        <CheckBox x:Name="AutoUpdateEverythingCheckBox" Content="自动检查并安装 Everything 稳定版更新" Margin="24,2,0,8" />
                        <TextBlock Text="首次启用时会从 voidtools 官方网站下载 x64 稳定版、校验 SHA-256，并请求管理员权限安装 Everything 服务。"
                                   TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="24,2,0,16" />

                        <TextBlock Text="托管目录" FontWeight="SemiBold" Margin="0,4,0,6" />
                        <TextBox x:Name="EverythingDirectoryTextBox" IsReadOnly="True" />
                        <TextBlock x:Name="EverythingManagedStatusTextBlock" Margin="0,8,0,16" Foreground="{DynamicResource SecondaryTextBrush}" />

                        <TextBlock Text="显示 Everything 热键" FontWeight="SemiBold" Margin="0,4,0,6" />
                        <TextBox x:Name="EverythingHotKeyTextBox" />
                        <TextBlock Text="例如 ^!F 表示 Ctrl+Alt+F。留空表示不注册 Everything 热键。"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,7,0,16" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="检查更新或安装" Click="UpdateEverything_Click" />
                            <Button Content="检测 SDK 连接" Margin="10,0,0,0" Click="TestEverything_Click" />
                        </StackPanel>
                        <TextBlock x:Name="EverythingStatusTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" IsCancel="True" Margin="0,0,10,0" />
            <Button Content="保存" IsDefault="True" Click="Save_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="RASharp.App.Menus.MenuEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:menus="clr-namespace:RASharp.Core.Menus;assembly=RASharp.Core"
        Title="RASharp 编辑菜单"
        Icon="/Assets/RASharp.ico"
        Width="980" Height="680" MinWidth="820" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="DragPaletteStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="TreeDragHandleStyle" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="ToolTip" Value="按住此手柄后拖动" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="菜单文件" VerticalAlignment="Center" Margin="0,0,10,0" />
            <ComboBox x:Name="MenuFileComboBox" Grid.Column="1"
                      SelectionChanged="MenuFileComboBox_SelectionChanged" />
            <TextBlock Grid.Column="2" Margin="14,0" VerticalAlignment="Center"
                       Text="从节点左侧手柄拖动可调整位置；右键节点可添加、删除或排序。保存后运行中的菜单会自动重新载入。"
                       TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" />
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="重新载入" Click="Reload_Click" />
                <Button Content="编辑菜单文件" Margin="8,0,0,0" Click="OpenFile_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="拖拽添加" VerticalAlignment="Center" FontWeight="SemiBold" />
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Category"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="拖到树中；放到分类中央会成为其子分类">
                    <TextBlock Text="添加分类" />
                </Border>
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Entry"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="拖到树中；放到分类中央会成为其子菜单项">
                    <TextBlock Text="添加菜单项" />
                </Border>
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Separator"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="拖到需要分隔的位置">
                    <TextBlock Text="添加分隔线" />
                </Border>
            </StackPanel>
            <Button Content="删除所选" HorizontalAlignment="Right" Click="Delete_Click" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="58*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource ControlBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <TreeView x:Name="MenuTreeView" BorderThickness="0" Padding="8"
                          AllowDrop="True"
                          SelectedItemChanged="MenuTreeView_SelectedItemChanged"
                          PreviewMouseMove="MenuTreeView_PreviewMouseMove"
                          PreviewMouseRightButtonDown="MenuTreeView_PreviewMouseRightButtonDown"
                          DragOver="MenuTreeView_DragOver"
                          Drop="MenuTreeView_Drop">
                    <TreeView.ContextMenu>
                        <ContextMenu Opened="TreeContextMenu_Opened">
                            <MenuItem Header="添加">
                                <MenuItem Header="添加分类" Tag="Category" Click="ContextAdd_Click" />
                                <MenuItem Header="添加应用（菜单项）" Tag="Entry" Click="ContextAdd_Click" />
                                <MenuItem Header="添加分隔线" Tag="Separator" Click="ContextAdd_Click" />
                            </MenuItem>
                            <Separator />
                            <MenuItem x:Name="ContextMoveTopMenuItem" Header="置顶" Click="ContextMoveTop_Click" />
                            <MenuItem x:Name="ContextMoveUpMenuItem" Header="上移" Click="ContextMoveUp_Click" />
                            <MenuItem x:Name="ContextMoveDownMenuItem" Header="下移" Click="ContextMoveDown_Click" />
                            <MenuItem x:Name="ContextMoveBottomMenuItem" Header="置底" Click="ContextMoveBottom_Click" />
                            <Separator />
                            <MenuItem x:Name="ContextDeleteMenuItem" Header="删除" Click="Delete_Click" />
                        </ContextMenu>
                    </TreeView.ContextMenu>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type menus:MenuEditorNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource TreeDragHandleStyle}"
                                        PreviewMouseLeftButtonDown="TreeDragHandle_PreviewMouseLeftButtonDown">
                                    <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                </Border>
                                <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="NodeTypeTextBlock" Text="请选择左侧节点"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

                        <TextBlock Text="名称" FontWeight="SemiBold" />
                        <TextBox x:Name="NameTextBox" Margin="0,6,0,12" />

                        <TextBlock Text="命令、网址或内容" FontWeight="SemiBold" />
                        <TextBox x:Name="ValueTextBox" Margin="0,6,0,12" AcceptsReturn="True" MinHeight="58" />

                        <TextBlock Text="全局热键" FontWeight="SemiBold" />
                        <TextBox x:Name="HotKeyTextBox" Margin="0,6,0,12" />
                        <CheckBox x:Name="RunAsAdministratorCheckBox"
                                  Content="以管理员身份运行" Margin="0,2,0,0" />
                        <TextBlock Text="分类只需编辑名称和热键；菜单项可编辑名称、命令和管理员运行。已有 DSL 的其他高级标记会保持不变。"
                                   TextWrapping="Wrap" Margin="0,12,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />

                        <Button x:Name="ApplyNodeButton" Content="应用到所选节点"
                                HorizontalAlignment="Left" Margin="0,18,0,0"
                                Click="ApplyNode_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="关闭" IsCancel="True" Click="Close_Click" />
                <Button Content="保存全部" Margin="10,0,0,0" IsDefault="True"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

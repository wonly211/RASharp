<Window x:Class="RASharp.App.Menus.MenuEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:menus="clr-namespace:RASharp.Core.Menus;assembly=RASharp.Core"
        Title="RASharp 编辑菜单"
        Icon="/Assets/RASharp.ico"
        Width="980" Height="680" MinWidth="820" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown"
        QueryContinueDrag="Window_QueryContinueDrag"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="DragPaletteStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="TreeDragHandleStyle" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="ToolTip" Value="从此手柄拖动节点" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="菜单文件" VerticalAlignment="Center" Margin="0,0,10,0" />
            <ComboBox x:Name="MenuFileComboBox" Grid.Column="1"
                      SelectionChanged="MenuFileComboBox_SelectionChanged" />
            <TextBlock Grid.Column="2" Margin="14,0" VerticalAlignment="Center"
                       Text="可用操作栏、快捷键或拖拽调整菜单；拖拽时会显示准确插入位置。保存后运行中的菜单会自动重新载入。"
                       TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" />
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="重新载入" Click="Reload_Click" />
                <Button Content="编辑菜单文件" Margin="8,0,0,0" Click="OpenFile_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="拖拽添加" VerticalAlignment="Center" FontWeight="SemiBold" />
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Category"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="拖到树中；放到分类中央会成为其子分类">
                    <TextBlock Text="添加分类" />
                </Border>
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Entry"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="拖到树中；放到分类中央会成为其子菜单项">
                    <TextBlock Text="添加菜单项" />
                </Border>
                <Border Style="{StaticResource DragPaletteStyle}" Tag="Separator"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="添加普通菜单分隔线 |">
                    <TextBlock Text="添加普通分隔线（|）" />
                </Border>
                <Border Style="{StaticResource DragPaletteStyle}" Tag="LevelSeparator"
                        PreviewMouseLeftButtonDown="Palette_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="Palette_PreviewMouseMove"
                        ToolTip="添加层级复位线；一级菜单中写为 -，之后的项目返回一级菜单">
                    <TextBlock Text="添加层级复位线（-）" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="58*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                    <TreeView x:Name="MenuTreeView" BorderThickness="0" Padding="8"
                              AllowDrop="True"
                              SelectedItemChanged="MenuTreeView_SelectedItemChanged"
                              PreviewMouseMove="MenuTreeView_PreviewMouseMove"
                              PreviewMouseRightButtonDown="MenuTreeView_PreviewMouseRightButtonDown"
                              DragOver="MenuTreeView_DragOver"
                              DragLeave="MenuTreeView_DragLeave"
                              Drop="MenuTreeView_Drop">
                        <TreeView.ContextMenu>
                            <ContextMenu Opened="TreeContextMenu_Opened">
                                <MenuItem x:Name="ContextUndoMenuItem" Header="撤销" InputGestureText="Ctrl+Z" Click="Undo_Click" />
                                <MenuItem x:Name="ContextRedoMenuItem" Header="重做" InputGestureText="Ctrl+Y" Click="Redo_Click" />
                                <Separator />
                                <MenuItem Header="添加">
                                    <MenuItem Header="添加分类" Tag="Category" Click="ContextAdd_Click" />
                                    <MenuItem Header="添加应用（菜单项）" Tag="Entry" Click="ContextAdd_Click" />
                                    <MenuItem Header="添加普通分隔线（|）" Tag="Separator" Click="ContextAdd_Click" />
                                    <MenuItem Header="添加层级复位线（-）" Tag="LevelSeparator" Click="ContextAdd_Click" />
                                </MenuItem>
                                <Separator />
                                <MenuItem x:Name="ContextMoveTopMenuItem" Header="置顶" InputGestureText="Ctrl+Home" Click="ContextMoveTop_Click" />
                                <MenuItem x:Name="ContextMoveUpMenuItem" Header="上移" InputGestureText="Alt+↑" Click="ContextMoveUp_Click" />
                                <MenuItem x:Name="ContextMoveDownMenuItem" Header="下移" InputGestureText="Alt+↓" Click="ContextMoveDown_Click" />
                                <MenuItem x:Name="ContextMoveBottomMenuItem" Header="置底" InputGestureText="Ctrl+End" Click="ContextMoveBottom_Click" />
                                <MenuItem x:Name="ContextPromoteMenuItem" Header="提升一级" InputGestureText="Alt+←" Click="Promote_Click" />
                                <MenuItem x:Name="ContextDemoteMenuItem" Header="降为子级" InputGestureText="Alt+→" Click="Demote_Click" />
                                <MenuItem x:Name="ContextMoveToMenuItem" Header="移动到分类…" Click="MoveToCategory_Click" />
                                <Separator />
                                <MenuItem x:Name="ContextDeleteMenuItem" Header="删除" InputGestureText="Delete" Click="Delete_Click" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type menus:MenuEditorNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource TreeDragHandleStyle}"
                                            PreviewMouseLeftButtonDown="TreeDragHandle_PreviewMouseLeftButtonDown">
                                        <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Border>

                <UniformGrid Grid.Row="1" Columns="5" Margin="0,8,0,0">
                    <Button x:Name="UndoButton" Content="↶ 撤销" Margin="2" ToolTip="Ctrl+Z" Click="Undo_Click" />
                    <Button x:Name="RedoButton" Content="↷ 重做" Margin="2" ToolTip="Ctrl+Y" Click="Redo_Click" />
                    <Button x:Name="MoveTopButton" Content="置顶" Margin="2" ToolTip="Ctrl+Home" Click="ContextMoveTop_Click" />
                    <Button x:Name="MoveUpButton" Content="↑ 上移" Margin="2" ToolTip="Alt+↑" Click="ContextMoveUp_Click" />
                    <Button x:Name="MoveDownButton" Content="↓ 下移" Margin="2" ToolTip="Alt+↓" Click="ContextMoveDown_Click" />
                    <Button x:Name="MoveBottomButton" Content="置底" Margin="2" ToolTip="Ctrl+End" Click="ContextMoveBottom_Click" />
                    <Button x:Name="PromoteButton" Content="← 提升" Margin="2" ToolTip="Alt+←，提升一级" Click="Promote_Click" />
                    <Button x:Name="DemoteButton" Content="→ 降级" Margin="2" ToolTip="Alt+→，移入前一个分类" Click="Demote_Click" />
                    <Button x:Name="MoveToButton" Content="移动到…" Margin="2" Click="MoveToCategory_Click" />
                    <Button x:Name="DeleteButton" Content="删除" Margin="2" ToolTip="Delete" Click="Delete_Click" />
                </UniformGrid>
            </Grid>

            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="NodeTypeTextBlock" Text="请选择左侧节点"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="名称" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="菜单热键" FontWeight="SemiBold" Margin="12,0,0,0" />
                            <TextBox x:Name="NameTextBox" Grid.Row="1" Margin="0,6,0,0" />
                            <TextBox x:Name="MenuAccessKeyTextBox" Grid.Row="1" Grid.Column="1"
                                     Margin="12,6,0,0" MaxLength="1"
                                     ToolTip="输入一个字母或数字，无需输入 &amp;、括号" />
                        </Grid>

                        <TextBlock Text="命令、网址或内容" FontWeight="SemiBold" />
                        <TextBox x:Name="ValueTextBox" Margin="0,6,0,12" AcceptsReturn="True" MinHeight="58" />

                        <TextBlock Text="全局热键（与菜单热键不同）" FontWeight="SemiBold" />
                        <TextBox x:Name="HotKeyTextBox" Margin="0,6,0,12" />
                        <CheckBox x:Name="RunAsAdministratorCheckBox"
                                  Content="以管理员身份运行" Margin="0,2,0,0" />
                        <TextBlock Text="菜单热键用于弹出菜单中的字母导航，输入单个字母或数字即可，保存时自动写成 (&amp;A)；全局热键用于直接从系统触发菜单项。已有 DSL 的其他高级标记会保持不变。"
                                   TextWrapping="Wrap" Margin="0,12,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />

                        <Button x:Name="ApplyNodeButton" Content="应用到所选节点"
                                HorizontalAlignment="Left" Margin="0,18,0,0"
                                Click="ApplyNode_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="关闭" IsCancel="True" Click="Close_Click" />
                <Button Content="保存全部" Margin="10,0,0,0" IsDefault="True"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

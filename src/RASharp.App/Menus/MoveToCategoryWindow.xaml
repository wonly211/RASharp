<Window x:Class="RASharp.App.Menus.MoveToCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="移动到分类"
        Icon="/Assets/RASharp.ico"
        Width="460" Height="520" MinWidth="400" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap" Margin="0,0,0,12" />

        <ListBox x:Name="TargetListBox" Grid.Row="1"
                 DisplayMemberPath="DisplayText"
                 BorderBrush="{DynamicResource BorderBrush}" />

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="插入位置" VerticalAlignment="Center" Margin="0,0,12,0" />
            <ComboBox x:Name="PositionComboBox" Grid.Column="1" SelectedIndex="1">
                <ComboBoxItem Content="目标分类开头" Tag="Start" />
                <ComboBoxItem Content="目标分类末尾" Tag="End" />
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" IsCancel="True" />
            <Button Content="移动" Margin="10,0,0,0" IsDefault="True" Click="Move_Click" />
        </StackPanel>
    </Grid>
</Window>
